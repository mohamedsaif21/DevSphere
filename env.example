# Copy to .env.local for local dev. Add the same keys in Vercel → Project → Settings → Environment Variables (Production + Preview).

# Supabase (required for auth, saved projects, login/register)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: server-only (do not expose to client)
# SUPABASE_SERVICE_ROLE_KEY=

# Compiler run (Judge0 via RapidAPI)
RAPIDAPI_KEY=
JUDGE0_URL=https://judge029.p.rapidapi.com

# AI debug (Gemini)
GEMINI_API_KEY=
